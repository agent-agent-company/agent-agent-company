# AAC Protocol Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Security Configuration
# ============================================================================

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here_min_32_chars_long

# Escrow/Payment Secret (for transaction signing)
ESCROW_SECRET=your_escrow_secret_key_here

# API Rate Limiting
REQUESTS_PER_MINUTE=60
MAX_FAILED_AUTH=5
BLOCK_DURATION_MINUTES=30

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# Provider: openai, deepseek, or custom (for OpenAI-compatible APIs)
LLM_PROVIDER=openai

# API Key (supports OpenAI, DeepSeek, or custom providers)
# For OpenAI: https://platform.openai.com/api-keys
# For DeepSeek: https://platform.deepseek.com/
OPENAI_API_KEY=your_api_key_here
# Or use generic key name:
# LLM_API_KEY=your_api_key_here

# Base URL (optional, for custom/OpenAI-compatible endpoints)
# LLM_BASE_URL=https://api.deepseek.com/v1

# Model Selection
LLM_CHAT_MODEL=gpt-3.5-turbo
# DeepSeek options: deepseek-chat (V3), deepseek-reasoner (R1)
# OpenAI options: gpt-3.5-turbo, gpt-4, gpt-4-turbo

# Embedding Model
LLM_EMBEDDING_MODEL=text-embedding-3-small
# OpenAI options: text-embedding-3-small, text-embedding-3-large

# Generation Parameters
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# Fallback Provider (optional, for redundancy)
# LLM_FALLBACK_PROVIDER=deepseek
# LLM_FALLBACK_API_KEY=your_fallback_key_here

# ============================================================================
# Database Configuration
# ============================================================================

# Database URL (defaults to SQLite for development)
# SQLite: sqlite+aiosqlite:///./aac_protocol.db
# PostgreSQL: postgresql+asyncpg://user:pass@localhost/aac_protocol
# MySQL: mysql+aiomysql://user:pass@localhost/aac_protocol
DATABASE_URL=sqlite+aiosqlite:///./aac_protocol.db

# Connection Pool Settings (for PostgreSQL/MySQL)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ============================================================================
# Network & Proxy Configuration
# ============================================================================

# Git/GitHub Proxy (if behind corporate firewall)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Git SSH Configuration (if using SSH)
# GIT_SSH_COMMAND=ssh -i ~/.ssh/id_rsa

# ============================================================================
# Platform Configuration
# ============================================================================

# Arbitration Settings
ARBITRATION_MIN_STAKE=100
MAX_COMPENSATION_NON_INTENTIONAL=5.0
MAX_COMPENSATION_INTENTIONAL=15.0
COMMUNITY_VOTES_REQUIRED=5

# Escrow Settings
ESCROW_TIME_LOCK_HOURS=24
MIN_PAYMENT_AMOUNT=0.01
MAX_PAYMENT_AMOUNT=100000

# Initial Balance for New Users (demo credits)
INITIAL_USER_BALANCE=1000.0
INITIAL_CREATOR_BALANCE=1000.0

# ============================================================================
# Development/Debug Settings
# ============================================================================

# Debug Mode (disable in production!)
DEBUG=false
LOG_LEVEL=INFO

# Testing Mode (uses mock LLM if no API key)
USE_MOCK_LLM=false

# Enable Detailed API Logging
API_DEBUG_LOGGING=false
